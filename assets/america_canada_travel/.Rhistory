values = c("0" = "grey40", "1" = "orange"),
labels = c("No", "Yes"),
name = "Visited Capital"
) +
theme_bw() +
theme(
axis.text = element_blank(),
panel.grid = element_blank(),
legend.position = "bottom"
) +
labs(
title = "Have I made significant travel to this state?"
)
